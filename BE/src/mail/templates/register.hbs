<html lang='vi'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Xác Thực Tài Khoản - CG Poker</title>
    <style>
      /* Reset styles dành riêng cho Email Clients */
      body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
      table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
      img { -ms-interpolation-mode: bicubic; }

      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        height: 100% !important;
        background-color: #081326;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #e2e8f0;
      }

      /* Kỹ thuật Responsive bằng Media Queries */
      @media screen and (max-width: 600px) {
        .container {
          width: 100% !important;
          max-width: 100% !important;
          border-radius: 0px !important; /* Tràn màn hình trên mobile cho đẹp */
          border-left: none !important;
          border-right: none !important;
        }
        .content {
          padding: 30px 20px !important;
        }
        .header {
          padding: 25px 20px !important;
        }
        .header h1 {
          font-size: 20px !important;
        }
        .otp-code {
          font-size: 28px !important;
          letter-spacing: 4px !important;
        }
        .welcome-text {
          font-size: 16px !important;
        }
        .body-text {
          font-size: 14px !important;
        }
      }
    </style>
  </head>
  <body>
    <!-- Wrapper chính bao ngoài cùng -->
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #081326; table-layout: fixed;">
      <tr>
        <td align="center" style="padding: 40px 0 20px 0;" class="content">
          
          <!-- Box nội dung chính (Container) -->
          <table border="0" cellpadding="0" cellspacing="0" width="600" class="container" style="background-color: #081326; border: 1px solid #16294A; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5); border-collapse: separate;">
            
            <!-- Header -->
            <tr>
              <td align="center" class="header" style="background-color: #0B1B33; padding: 35px; border-bottom: 1px solid #16294A;">
                <h1 style="margin: 0; font-size: 24px; font-weight: 800; color: #facc15; letter-spacing: 1.5px; text-transform: uppercase;">♠️ CG POKER CLASSIC ♦️</h1>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td class="content" style="padding: 40px 30px; line-height: 1.6;">
                <div class="welcome-text" style="font-size: 18px; color: #ffffff; font-weight: bold; text-align: center; margin-bottom: 25px;">
                  Chào mừng người chơi {{username}}!
                </div>
                
                <div class="body-text" style="font-size: 15px; color: #94a3b8; margin-bottom: 20px; text-align: center;">
                  Cảm ơn bạn đã đăng ký gia nhập cổng game bài đỉnh cao <strong style="color: #facc15; font-weight: 600;">CG Poker</strong>. 
                  Để kích hoạt tài khoản vui lòng xác thực tài khoản bằng mã OTP dưới đây.
                </div>

                <!-- OTP Box -->
                <table border="0" cellpadding="0" cellspacing="0" width="100%">
                  <tr>
                    <td align="center" style="padding: 10px 0;">
                      <div style="background-color: #0B1B33; border: 1px solid #1e3a5f; border-radius: 12px; padding: 24px; text-align: center; width: 85%;">
                        <span style="font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 8px; display: block; font-weight: 600;">Mã Xác Thực OTP</span>
                        <div class="otp-code" style="font-size: 38px; font-weight: 800; color: #facc15; letter-spacing: 8px; margin: 12px 0;">{{otp}}</div>
                        <div style="font-size: 12px; color: #94a3b8;">Hiệu lực trong vòng <strong style="color: #facc15;">15 phút</strong></div>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td class="footer" style="background-color: #0B1B33; padding: 25px; text-align: center; font-size: 12px; color: #64748b; border-top: 1px solid #16294A; line-height: 1.5;">
                <p style="margin: 0 0 8px 0;">Email này được gửi tự động từ hệ thống CG Poker. Vui lòng không trả lời thư này.</p>
                <p style="margin: 0;">
                  Hỗ trợ khách hàng 24/7: 
                  <a href="mailto:support@cgpoker.com" style="color: #facc15; text-decoration: none; font-weight: 600;">support@cgpoker.com</a>
                </p>
              </td>
            </tr>

          </table>
          
        </td>
      </tr>
    </table>
  </body>
</html>